# Aquora storefront (Next.js) — all NEXT_PUBLIC_* vars are baked into the client bundle at
# `next build`, so they are PUBLIC by definition. Copy to .env.local (dev) / .env.production
# (build) and fill in. No server secrets belong here.

# Medusa backend the storefront talks to (Ask Aqua, /store/recommend, /store/event, cart).
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://api.aquora.ae
# Publishable API key (public) — identifies the sales channel; not a secret.
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_...
# Default region / country code (UAE).
NEXT_PUBLIC_DEFAULT_REGION=ae
# Canonical site origin (used for absolute URLs / SEO).
NEXT_PUBLIC_BASE_URL=https://aquora.ae

# Analytics (optional) — GA4 measurement id + GTM container id.
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GTM_ID=

# Stripe publishable key (public) for card payments (optional in dev).
NEXT_PUBLIC_STRIPE_KEY=pk_...
